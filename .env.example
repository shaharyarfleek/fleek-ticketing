# Google BigQuery Configuration
# Option 1: Using a service account key file
VITE_BIGQUERY_PROJECT_ID=your-project-id
VITE_BIGQUERY_KEY_PATH=/path/to/your/service-account-key.json

# Option 2: Using inline credentials (paste the entire JSON key as a string)
# VITE_BIGQUERY_CREDENTIALS='{"type":"service_account","project_id":"your-project-id","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}'

# BigQuery Dataset and Table Configuration
VITE_BIGQUERY_DATASET_ID=orders
VITE_BIGQUERY_TABLE_ID=order_lines

# Expected table schema for order_lines:
# - order_line_id (STRING) - Unique identifier for the order line
# - order_value (FLOAT64) - The monetary value of the order
# - currency (STRING) - Currency code (e.g., 'GBP', 'USD', 'EUR')
# - order_date (TIMESTAMP) - When the order was placed
# - customer_name (STRING) - Name of the customer (optional)